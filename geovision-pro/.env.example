# Copy to .env and adjust. Consumed by docker-compose and the backend.

# --- Vision model ---
# Strongest geolocation model (large, ~600MB download on first run):
GEOVISION_VISION_MODEL=geolocal/StreetCLIP
# Lightweight fallback used automatically if the above fails to load:
GEOVISION_VISION_FALLBACK_MODEL=openai/clip-vit-base-patch32
# auto | cpu | cuda
GEOVISION_DEVICE=auto
GEOVISION_MODEL_LAZY_LOAD=true

# --- GeoCLIP accuracy boosters (no training; cost a bit more CPU time) ---
# Evaluate the image AND its mirror, fuse the gallery probabilities (more stable):
GEOVISION_GEOCLIP_TTA=true
# Gallery entries fused before picking the final candidates:
GEOVISION_GEOCLIP_CANDIDATE_POOL=64
# Down-weight GeoCLIP coordinates whose country contradicts StreetCLIP's guess:
GEOVISION_GEOCLIP_COUNTRY_RERANK=true

# --- Database ---
GEOVISION_DATABASE_URL=postgresql+asyncpg://geovision:geovision@db:5432/geovision

# --- Geocoding (OpenStreetMap Nominatim) ---
# Identify yourself per the Nominatim usage policy (an email):
GEOVISION_NOMINATIM_EMAIL=

# --- Picarta (commercial GeoSpy-class API; closest to GeoSpy accuracy) ---
# Get a free-tier token at https://picarta.ai and paste it here to enable it.
# Leave empty to stay fully on the open models (GeoCLIP / StreetCLIP).
GEOVISION_PICARTA_API_TOKEN=
GEOVISION_ENABLE_PICARTA=true
GEOVISION_PICARTA_TOP_K=3

# --- Reference gallery ("training with more images", the honest/free way) ---
# Folder of YOUR OWN geotagged images. We embed them once (cached on disk) and
# match new photos against them — real image retrieval. The more geotagged
# photos you add, the more places the app recognises. Coordinates come from each
# image's EXIF GPS, or from a "lat,lon" pattern in the filename
# (e.g. cafe_48.8584_2.2945.jpg). Empty path disables it.
GEOVISION_REFERENCE_DIR=
# Cosine similarity needed to trust a gallery match as a location (0..1):
GEOVISION_REFERENCE_MIN_SIMILARITY=0.86
# How many nearest neighbours to fuse into the estimate:
GEOVISION_REFERENCE_USE_TOP_K=5

# --- Other optional features ---
# Requires the tesseract-ocr binary (already in the backend Docker image):
GEOVISION_ENABLE_OCR=true
GEOVISION_MAX_VIDEO_FRAMES=12
GEOVISION_UPLOAD_MAX_MB=40
